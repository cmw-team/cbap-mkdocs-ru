#!/usr/bin/env bash
set -euo pipefail

# Suggest [#XXXXX] prefix from branch or recent commits — never mutate the message file.
# Usage: prepare-commit-msg <commit-msg-file> [<commit-source>] [<sha1>]
MSG_FILE="$1"

# Skip for merge commits
if git rev-parse -q --verify MERGE_HEAD >/dev/null 2>&1; then
  exit 0
fi

first_line="$(head -n1 "$MSG_FILE" || true)"

# Already formatted, or merge/revert — nothing to suggest
if printf '%s' "$first_line" | grep -qE '^\[\#[0-9]+\] '; then
  exit 0
fi
if printf '%s' "$first_line" | grep -qE '^(Merge|Revert) '; then
  exit 0
fi

branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
issue=""

# YYYYMMDD_<ticket>_<theme>
if printf '%s' "$branch" | grep -qE '^[0-9]{8}_[0-9]+_'; then
  issue="$(printf '%s' "$branch" | sed -n 's/^[0-9]\{8\}_\([0-9][0-9]*\)_.*/\1/p')"
# Legacy <ticket>_<theme> (not a date-only prefix)
elif printf '%s' "$branch" | grep -qE '^[0-9]+_'; then
  issue="$(printf '%s' "$branch" | sed -n 's/^\([0-9][0-9]*\)_.*/\1/p')"
fi

# Do not infer [#6]/[#5] from platform_v6 / platform_v5 branch names — too easy to mislead.

if [ -z "$issue" ]; then
  issue="$(git log -n 20 --pretty=%B | sed -n 's/^\[\#\([0-9][0-9]*\)\].*/\1/p' | head -1 || true)"
fi

if [ -n "$issue" ]; then
  echo "prepare-commit-msg: suggest format [#${issue}] ${first_line}" 1>&2
  echo "prepare-commit-msg: edit the message or use: git commit -m \"[#${issue}] ${first_line}\"" 1>&2
else
  echo "prepare-commit-msg: suggest prefix [#XXXXX] on the first line (see .agents/skills/cmwhelp-commit/SKILL.md)" 1>&2
fi

exit 0
